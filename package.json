{
  "name": "stratuu-brain-mcp",
  "version": "0.1.0-alpha",
  "description": "Brain MCP server — shared persistent memory between Stratuu desktop and CLI agents (Claude Code, Codex, Gemini CLI). Bun + SQLite.",
  "module": "src/index.ts",
  "type": "module",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/Haamiahphp/stratuu-brain-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Haamiahphp/stratuu-brain-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Haamiahphp/stratuu-brain-mcp/issues"
  },
  "bin": {
    "stratuu-brain-mcp": "bin/stratuu-brain-mcp.ts"
  },
  "scripts": {
    "start": "bun run bin/stratuu-brain-mcp.ts",
    "dev": "bun --hot run bin/stratuu-brain-mcp.ts",
    "test": "bun test",
    "build": "bun build bin/stratuu-brain-mcp.ts --compile --outfile dist/stratuu-brain-mcp",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "brain",
    "memory",
    "sqlite",
    "bun",
    "stratuu",
    "vibe-coding"
  ]
}
